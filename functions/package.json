{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint .",
    "test": "jest --runInBand __tests__",
    "test:pact:consumer": "jest --runInBand --runTestsByPath pact/consumer.pact.test.js",
    "test:pact:provider": "jest --runInBand --runTestsByPath pact/provider.pact.test.js",
    "test:pact": "npm run test:pact:consumer && npm run test:pact:provider"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.1.1"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.2.0",
    "eslint": "^10.0.3",
    "firebase-functions-test": "^3.1.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "private": true
}
